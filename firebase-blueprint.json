{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "Customer appointment booking details and uploaded documents",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique key for tracking"
        },
        "serviceName": {
          "type": "string",
          "description": "Name of service booked"
        },
        "customerName": {
          "type": "string",
          "description": "Name of client"
        },
        "phone": {
          "type": "string",
          "description": "Mobile number"
        },
        "email": {
          "type": "string",
          "description": "Client email"
        },
        "date": {
          "type": "string",
          "description": "Date of appointment"
        },
        "status": {
          "type": "string",
          "enum": ["Pending Review", "Processing", "Documents Verified", "Completed"],
          "description": "Status of the appointment"
        },
        "files": {
          "type": "array",
          "description": "List of base64 document payloads"
        },
        "notes": {
          "type": "string",
          "description": "Optional notes from client"
        },
        "userId": {
          "type": "string",
          "description": "UID of the user who booked"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last updated timestamp"
        }
      },
      "required": ["id", "serviceName", "customerName", "phone", "status", "createdAt"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "Images for shop gallery uploaded by admins",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "titleEn": { "type": "string" },
        "titleHi": { "type": "string" },
        "cat": { "type": "string" },
        "base64Image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "titleEn", "titleHi", "cat", "base64Image", "createdAt"]
    },
    "TeamProfile": {
      "title": "Team Profile",
      "description": "Profile images for team members",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "base64Image": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "base64Image"]
    }
  },
  "firestore": {
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of appointments and uploaded files"
    },
    "galleryImages/{imageId}": {
      "schema": "GalleryImage",
      "description": "Collection of gallery images"
    },
    "teamProfiles/{profileId}": {
      "schema": "TeamProfile",
      "description": "Collection of team profile images"
    }
  }
}
